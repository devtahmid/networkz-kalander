
## `.gitignore`

```gitignore
# frontend
frontend/node_modules/
frontend/build/

# backend
backend/.venv/
backend/__pycache__/
backend/**/*.pyc

# env files
.env
backend/.env
frontend/.env

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor files
.DS_Store
Thumbs.db
.vscode/
.idea/